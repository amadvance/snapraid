#!/bin/bash
# makeslackdist.sh - Creates the source distribution for SlackBuilds.org

set -euo pipefail

PRGNAM="@PACKAGE@"
VERSION="@PACKAGE_VERSION@"
TARBALL="@PACKAGE@.tar.gz"
SOURCE_TARBALL="@PACKAGE@-${VERSION}.tar.gz"
STAGING_DIR="${PRGNAM}-slack-dist-root"

echo "Calculating MD5 sum..."
MD5SUM=$(md5sum "$SOURCE_TARBALL" | cut -d' ' -f1)

# Clean previous builds
rm -rf "${STAGING_DIR}"

# Create a temporary staging area
mkdir -p $STAGING_DIR/$PRGNAM

# Copy Build Files from the pkg directory
cp pkg/$PRGNAM.SlackBuild $STAGING_DIR/$PRGNAM/
cp pkg/slack-desc $STAGING_DIR/$PRGNAM/
cp pkg/doinst.sh $STAGING_DIR/$PRGNAM/
cp pkg/README $STAGING_DIR/$PRGNAM/

# Process the .info file and replace placeholders 
sed -e "s/@MD5SUM@/$MD5SUM/g" pkg/$PRGNAM.info > $STAGING_DIR/$PRGNAM/$PRGNAM.info

# We create the tarball in the current root directory
tar --owner=0 --group=0 -czf "$TARBALL" -C $STAGING_DIR $PRGNAM

# Cleanup
rm -rf $STAGING_DIR

echo ""
echo "Success! The tarball is: $TARBALL"
echo "MD5SUM updated to: $MD5SUM"
